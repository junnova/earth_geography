# 依赖（勿提交，在各目录执行 npm install）
node_modules/

# 前端构建产物
client/dist
client/dist-ssr

# 本地 / 密钥环境变量
.env
.env.*
!.env.example

# 日志
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 操作系统
.DS_Store
Thumbs.db

# 编辑器（如需共享 VS Code 推荐扩展，可保留 extensions.json）
.idea
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vite / 工具缓存
client/*.local

# SQLite 运行时产生的辅助文件（主库 landmarks.db 如需协作可继续提交）
*.db-shm
*.db-wal

# 用户通过后台上传的文件
server/uploads/*
!server/uploads/.gitkeep
